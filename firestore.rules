rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /recipes/{recipeId} {
      // Anyone can view recipes.
      allow read: if true;

      // Admins (currently just Matt) can add/edit/delete any recipe.
      function isAdmin() {
        return request.auth != null && request.auth.uid in [
          "ME9lRZmaDYUSwFR0qIhc1TbUqV13"
        ];
      }

      // Contributors can only touch recipes filed under their own
      // category. To add Nate, uncomment his line below and put his
      // real UID in. Add Stephen the same way later.
      function contributorCategory() {
        return {
          "bKqnTuR99VW4oV2vHUtckM0Ao4K3": "Nasty Nate's Corner"
          // "STEPHEN_UID_HERE": "Stephen's Snacks"
        }[request.auth.uid];
      }

      allow create, update: if isAdmin() ||
        (request.auth != null && request.resource.data.category == contributorCategory());

      allow delete: if isAdmin() ||
        (request.auth != null && resource.data.category == contributorCategory());
    }
  }
}
